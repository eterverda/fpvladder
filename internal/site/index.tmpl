<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ .Title }}</title>
    <link rel="stylesheet" href="styles.css?v={{ now }}">
</head>
<body data-has-back="false">
    {{template "header"}}

    <div class="container">
        <div class="class-tabs">
            {{ range .Classes }}
            <button class="class-tab" data-class="{{ .ParamValue }}">{{ .ClassName }}</button>
            {{ end }}
        </div>

        <div class="search-wrapper">
            <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16zm10 2l-4.35-4.35"/></svg>
            <input type="text" class="search-input" placeholder="Поиск" autocomplete="off">
            <div class="search-filters">
                <button class="search-filter" data-filter="heart" title="Избранное">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                    </svg>
                </button>
                <button class="search-filter" data-filter="star" title="Звёздочки">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                    </svg>
                </button>
                <button class="search-filter" data-filter="flag" title="Флажки">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path>
                        <line x1="4" y1="22" x2="4" y2="15"></line>
                    </svg>
                </button>
                <button class="search-clear" title="Очистить поиск" style="display: none;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
        </div>

        {{ range .Classes }}
        <div class="class-content" data-class="{{ .ParamValue }}">

            <section class="future-events-section" data-has-events="{{ if .FutureEvents }}true{{ else }}false{{ end }}">
                <h2 class="future-events-toggle">
                    <span class="future-events-title">
                        Предстоящие
                        <nobr>
                            события
                            <a href="webcal://fpvladder.ru/calendar.ics" type="text/calendar" class="calendar-link" title="Подписаться на календарь">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                                </svg>
                            </a>
                        </nobr>
                    </span>
                    <button class="toggle-btn" aria-label="Свернуть/развернуть" aria-expanded="true">
                        <svg class="toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="18 15 12 9 6 15"></polyline>
                        </svg>
                    </button>
                </h2>
                <div class="future-events-content">
                    <table class="data-table future-event-table">
                    <tbody class="future-event-table-body">
                        {{ range .FutureEvents }}
                        <tr class="data-row" data-href="{{ .Href }}" data-id="{{ .Id }}">
                            <td class="col-info future-event-countdown" data-date="{{ .Date }}"></td>
                            <td class="col-name">
                                <div class="event-row-content">
                                    <a href="{{ .Href }}">{{ .Name }} {{template "favorites-tags" .Id}}{{template "favorites-widget" .Id}}</a>
                                    <span class="event-date">{{ .Date }}</span>
                                </div>
                            </td>
                        </tr>
                        {{ end }}
                    </tbody>
                </table>
                <div class="future-events-empty empty-state">Предстоящие события не найдены</div>
                </div>
            </section>

            <section>
                <h2>Пилоты</h2>
                <table class="data-table pilot-table">
                    <tbody class="pilot-table-body">
                        {{ range .Pilots }}
                        <tr class="data-row" data-href="{{ .Href }}" data-id="{{ .Id }}" data-position="{{ .Position.Int }}">
                            <td class="col-info">{{ if le .Position.Int 10 }}{{ .Position }}{{ end }}</td>
                            <td class="col-name">
                                <div class="event-row-content">
                                    <a href="{{ .Href }}">{{ .Name }} {{template "favorites-tags" .Id}}{{template "favorites-widget" .Id}}</a>
                                    <span class="meta-value" data-rank="{{ .Position.Int }}">{{ .Rating }}</span>
                                </div>
                            </td>
                        </tr>
                        {{ end }}
                    </tbody>
                </table>
                <div class="pilots-empty empty-state">Пилоты не найдены</div>
            </section>

            <section class="events-section">
                <h2 class="events-toggle">
                    <span>События</span>
                    <button class="toggle-btn" aria-label="Свернуть/развернуть" aria-expanded="true">
                        <svg class="toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="18 15 12 9 6 15"></polyline>
                        </svg>
                    </button>
                </h2>
                <div class="events-content">
                    <table class="data-table event-table">
                        <tbody class="event-table-body">
                            {{ range .Events }}
                            <tr class="data-row" data-href="{{ .Href }}" data-id="{{ .Id }}">
                                <td class="col-info">
                                    {{ .NumPilots }}<svg class="user-icon"><use href="#icon-user"></use></svg>
                                </td>
                                <td class="col-name">
                                    <div class="event-row-content">
                                        <a href="{{ .Href }}">{{ .Name }} {{template "favorites-tags" .Id}}{{template "favorites-widget" .Id}}</a>
                                        <span class="event-date">{{ .Date }}</span>
                                    </div>
                                </td>
                            </tr>
                            {{ end }}
                        </tbody>
                    </table>
                    <div class="events-empty empty-state">События не найдены</div>
                </div>
            </section>
        </div>
        {{ end }}

        <footer>
            <div class="manifest-box">
                FPV Ladder — это независимый открытый рейтинг Fpv пилотов с добровольным участием. Читать <a href="manifest.html">Манифест</a>.
            </div>
            <div class="footer-info">
                <span>Обновлено: {{ .GeneratedAt }}</span>
                <a href="https://t.me/fpvladder" class="tg-link">Написать нам</a>
            </div>
            <div class="copyright">&copy; 2026 FPV Ladder Project</div>
        </footer>
    </div>

    <script src="scripts.js?v={{ now }}"></script>
    <script>
        // Search clear button and input
        const searchClearBtn = document.querySelector('.search-clear');
        const searchInput = document.querySelector('.search-input');

        // Search functionality for all class contents
        function performSearch(query) {
            query = query.toLowerCase();

            // Re-apply favorites UI (filters + widgets)
            window.refreshFavoritesUI();

            document.querySelectorAll('.class-content').forEach(content => {
                const futureTbody = content.querySelector('.future-event-table-body');
                const pilotTbody = content.querySelector('.pilot-table-body');
                const eventTbody = content.querySelector('.event-table-body');
                const futureTable = content.querySelector('.future-event-table');
                const pilotTable = content.querySelector('.pilot-table');
                const eventTable = content.querySelector('.event-table');
                const futureEmpty = content.querySelector('.future-events-empty');
                const pilotsEmpty = content.querySelector('.pilots-empty');
                const eventsEmpty = content.querySelector('.events-empty');

                if (futureTbody) updateVisibility(futureTbody, futureTable, futureEmpty, query);
                if (pilotTbody) updateVisibility(pilotTbody, pilotTable, pilotsEmpty, query);
                if (eventTbody) updateVisibility(eventTbody, eventTable, eventsEmpty, query);
            });
        }

        searchInput.addEventListener('input', (e) => {
            performSearch(e.target.value);
        });

        function updateVisibility(tbody, table, emptyState, query) {
            const rows = tbody.querySelectorAll('.data-row');
            let foundAny = false;
            rows.forEach(row => {
                const name = row.querySelector('.col-name').textContent.toLowerCase();
                if (name.includes(query)) {
                    row.style.display = '';
                    foundAny = true;
                } else {
                    row.style.display = 'none';
                }
            });
            if (table) table.style.display = foundAny ? 'table' : 'none';
            if (emptyState) emptyState.style.display = foundAny ? 'none' : 'block';
        }

        if (searchClearBtn && searchInput) {
            searchClearBtn.addEventListener('click', () => {
                searchInput.value = '';
                searchClearBtn.style.display = 'none';
                performSearch('');
                searchInput.focus();
            });
        }

        // Wrap performSearch to show/hide clear button and mark search active
        const originalPerformSearch = performSearch;
        performSearch = function(query) {
            originalPerformSearch(query);
            if (searchClearBtn) {
                searchClearBtn.style.display = query.length > 0 ? 'flex' : 'none';
            }
            // Mark body as having search active for CSS to hide collapsed headers
            document.body.classList.toggle('search-active', query.length > 0);
        };
    </script>
</body>
</html>
