<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ .Title }}</title>
    <style>
        :root {
            --bg: #ffffff;
            --text: #2d3436;
            --muted: #b2bec3;
            --line: #eee;
            --hover-bg: #fcfcfc;
            --input-border: #dfe6e9;
            --accent: #0088cc;
        }

        body {
            font-family: 'Segoe UI', Roboto, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            display: flex;
            justify-content: center;
            margin: 0;
            padding: 40px 20px 80px 20px;
        }

        .container { width: 100%; max-width: 600px; }

        h1 { text-align: center; font-weight: 400; font-size: 1.5rem; margin-bottom: 25px; }
        
        h2 { 
            font-size: 0.8rem; 
            font-weight: 700; 
            color: var(--muted); 
            text-transform: uppercase; 
            letter-spacing: 1.5px; 
            margin: 40px 0 10px 75px; 
        }

        .search-wrapper { margin: 0 30px 25px 35px; position: relative; }
        .search-icon {
            position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
            width: 16px; height: 16px; fill: var(--muted);
        }
        .search-input {
            width: 100%; padding: 10px 30px 10px 38px; font-size: 0.9rem;
            border: 1px solid var(--input-border); border-radius: 6px; outline: none;
            box-sizing: border-box; transition: border-color 0.2s;
        }
        .search-input:focus { border-color: var(--muted); }

        .data-table { width: 100%; border-collapse: collapse; }
        .data-row { border-bottom: 1px solid var(--line); transition: background 0.1s; }
        .data-row:hover { background-color: var(--hover-bg); }
        .data-row td { padding: 12px 15px; -webkit-tap-highlight-color: transparent; }
        .data-row:last-child { border-bottom: none; }

        /* Кликабельность строки */
        .data-row[data-href] { cursor: pointer; }
        .data-row a { text-decoration: none; color: inherit; display: block; }
        .data-row:hover .col-name a { text-decoration: underline; text-underline-offset: 4px; }

        /* Мобильный отклик */
        @media (hover: none) {
            .data-row:active { background-color: #f2f2f2; transition: background 0s; }
        }

        .col-hover-info {
            text-align: right; width: 30px; font-size: 0.75rem; color: var(--muted);
            opacity: 0; transition: opacity 0.2s ease; white-space: nowrap;
        }
        .data-row:hover .col-hover-info { opacity: 1; }

        .col-name { font-weight: 400; font-size: 1rem; }

        .col-right {
            text-align: right; width: 110px; 
            white-space: nowrap;
        }

        .col-right-bold {
            text-align: right; font-weight: 600; width: 110px; 
            white-space: nowrap;
        }

        .user-icon { width: 11px; height: 11px; fill: var(--muted); vertical-align: 0px; margin-left: 1px; }

        .empty-state {
            padding: 20px 0 20px 75px;
            color: var(--muted); 
            font-size: 0.85rem; 
            display: none;
            font-style: italic;
        }

        .manifest-box {
            margin-top: 60px;
            padding: 20px 25px;
            border: 1px solid var(--line);
            border-radius: 12px;
            font-size: 0.85rem;
            color: #636e72;
        }

        .manifest-box a { color: var(--text); text-decoration: underline; text-underline-offset: 3px; }
        .manifest-box a:hover { color: var(--accent); }

        .footer-info {
            margin-top: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 10px;
            color: var(--muted);
            font-size: 0.75rem;
        }

        .tg-link {
            display: flex;
            align-items: center;
            text-decoration: none;
            color: var(--muted) !important;
            font-weight: 600;
            transition: color 0.2s;
        }

        .tg-link:hover { color: var(--accent) !important; }
        .tg-icon { width: 14px; height: 14px; fill: currentColor; margin-right: 5px; }

        .copyright {
            margin-top: 40px;
            text-align: center;
            font-size: 0.75rem;
            color: var(--muted);
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>{{ .Title }}</h1>
        
        <div class="search-wrapper">
            <svg class="search-icon" viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
            <input type="text" id="mainSearch" class="search-input" placeholder="Поиск" autocomplete="off">
        </div>

        <section>
            <h2>Пилоты</h2>
            <table class="data-table" id="pilotTable">
                <tbody id="pilotTableBody">
                    {{ range .Pilots }}
                    <tr class="data-row" data-href="{{ .Href }}">
                        <td class="col-hover-info">{{ .Position }}</td>
                        <td class="col-name"><a href="{{ .Href }}">{{ .Name }}</a></td>
                        <td class="col-right-bold">{{ .Rating }}</td>
                    </tr>
                    {{ end }}
                </tbody>
            </table>
            <div id="pilots-empty" class="empty-state">Пилоты не найдены</div>
        </section>

        <section>
            <h2>События</h2>
            <table class="data-table" id="eventTable">
                <tbody id="eventTableBody">
                    {{ range .Events }}
                    <tr class="data-row">
                        <td class="col-hover-info">
                            {{ .NumPilots }}<svg class="user-icon" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                        </td>
                        <td class="col-name">{{ .Name }}</td>
                        <td class="col-right">{{ .Date }}</td>
                    </tr>
                    {{ end }}
                </tbody>
            </table>
            <div id="events-empty" class="empty-state">События не найдены</div>
        </section>

        <footer>
            <div class="manifest-box">
                FPV Ladder — это независимый открытый рейтинг Fpv пилотов с добровольным участием. Читать <a href="manifest.html">Манифест</a>.
            </div>
            
            <div class="footer-info">
                <span>Обновлено: {{ .GeneratedAt }}</span>
                <a href="https://t.me/yourchannel" class="tg-link">
                    <svg class="tg-icon" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z"/></svg>
                    Написать нам
                </a>
            </div>
            
            <div class="copyright">
                FPV Ladder Project &copy; 2026
            </div>
        </footer>
    </div>

    <script>
        const searchInput = document.getElementById('mainSearch');
        
        searchInput.addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase();
            updateVisibility('pilotTableBody', 'pilotTable', 'pilots-empty', query);
            updateVisibility('eventTableBody', 'eventTable', 'events-empty', query);
        });

        function updateVisibility(tbodyId, tableId, emptyId, query) {
            const tbody = document.getElementById(tbodyId);
            const table = document.getElementById(tableId);
            const emptyState = document.getElementById(emptyId);
            const rows = tbody.querySelectorAll('.data-row');
            let foundAny = false;

            rows.forEach(row => {
                const name = row.querySelector('.col-name').textContent.toLowerCase();
                if (name.includes(query)) {
                    row.style.display = '';
                    foundAny = true;
                } else {
                    row.style.display = 'none';
                }
            });

            table.style.display = foundAny ? 'table' : 'none';
            emptyState.style.display = foundAny ? 'none' : 'block';
        }

        // Клик по всей строке
        document.addEventListener('click', (e) => {
            const row = e.target.closest('.data-row[data-href]');
            if (row && !e.target.closest('a')) {
                window.location.href = row.dataset.href;
            }
        });
    </script>
</body>
</html>
