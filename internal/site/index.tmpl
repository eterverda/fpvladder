<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ .Title }}</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body data-has-back="false">
    {{template "header"}}

    <div class="container">
        <h1>{{ .Title }}</h1>

        {{ range .Classes }}
        <div class="class-content" data-class="{{ .ParamValue }}">

            <section class="future-events-section" data-has-events="{{ if .FutureEvents }}true{{ else }}false{{ end }}">
                <h2 class="table-header">
                    Предстоящие события
                    <a href="webcal://fpvladder.ru/calendar.ics" type="text/calendar" style="text-decoration: none; margin-left: 8px;" title="Подписаться на календарь">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; color: var(--muted);">
                            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                        </svg>
                    </a>
                </h2>
                <table class="data-table future-event-table">
                    <tbody>
                        {{ range .FutureEvents }}
                        <tr class="data-row" data-href="{{ .Href }}">
                            <td class="col-spacer">&nbsp;</td>
                            <td class="col-name"><a href="{{ .Href }}">{{ .Name }}</a></td>
                            <td class="col-right">{{ .Date }}</td>
                        </tr>
                        {{ end }}
                    </tbody>
                </table>
            </section>

            <div class="search-wrapper">
                <svg class="search-icon" viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                <input type="text" class="search-input" placeholder="Поиск" autocomplete="off">
            </div>

            <section>
                <h2 class="table-header">Пилоты</h2>
                <table class="data-table pilot-table">
                    <tbody class="pilot-table-body">
                        {{ range .Pilots }}
                        <tr class="data-row" data-href="{{ .Href }}">
                            <td class="col-hover-info">{{ .Position }}</td>
                            <td class="col-name"><a href="{{ .Href }}">{{ .Name }}</a></td>
                            <td class="col-right-bold">{{ .Rating }}</td>
                        </tr>
                        {{ end }}
                    </tbody>
                </table>
                <div class="pilots-empty empty-state">Пилоты не найдены</div>
            </section>

            <section>
                <h2 class="table-header">События</h2>
                <table class="data-table event-table">
                    <tbody class="event-table-body">
                        {{ range .Events }}
                        <tr class="data-row" data-href="{{ .Href }}">
                            <td class="col-hover-info">
                                {{ .NumPilots }}<svg class="user-icon" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                            </td>
                            <td class="col-name"><a href="{{ .Href }}">{{ .Name }}</a></td>
                            <td class="col-right">{{ .Date }}</td>
                        </tr>
                        {{ end }}
                    </tbody>
                </table>
                <div class="events-empty empty-state">События не найдены</div>
            </section>
        </div>
        {{ end }}

        <footer>
            <div class="manifest-box">
                FPV Ladder — это независимый открытый рейтинг Fpv пилотов с добровольным участием. Читать <a href="manifest.html">Манифест</a>.
            </div>
            <div class="footer-info">
                <span>Обновлено: {{ .GeneratedAt }}</span>
                <a href="https://t.me/fpvladder" class="tg-link">Написать нам</a>
            </div>
            <div class="copyright">&copy; 2026 FPV Ladder Project</div>
        </footer>
    </div>

    <script src="scripts.js"></script>
    <script>
        // Search functionality for each class content
        document.querySelectorAll('.class-content').forEach(content => {
            const searchInput = content.querySelector('.search-input');
            if (searchInput) {
                searchInput.addEventListener('input', (e) => {
                    const query = e.target.value.toLowerCase();
                    const pilotTbody = content.querySelector('.pilot-table-body');
                    const eventTbody = content.querySelector('.event-table-body');
                    const pilotTable = content.querySelector('.pilot-table');
                    const eventTable = content.querySelector('.event-table');
                    const pilotsEmpty = content.querySelector('.pilots-empty');
                    const eventsEmpty = content.querySelector('.events-empty');

                    if (pilotTbody) updateVisibility(pilotTbody, pilotTable, pilotsEmpty, query);
                    if (eventTbody) updateVisibility(eventTbody, eventTable, eventsEmpty, query);
                });
            }
        });

        function updateVisibility(tbody, table, emptyState, query) {
            const rows = tbody.querySelectorAll('.data-row');
            let foundAny = false;
            rows.forEach(row => {
                const name = row.querySelector('.col-name').textContent.toLowerCase();
                if (name.includes(query)) {
                    row.style.display = '';
                    foundAny = true;
                } else {
                    row.style.display = 'none';
                }
            });
            if (table) table.style.display = foundAny ? 'table' : 'none';
            if (emptyState) emptyState.style.display = foundAny ? 'none' : 'block';
        }
    </script>
</body>
</html>
