{{define "header"}}
{{template "symbols"}}
<header class="site-header">
    <div class="header-container">
        <div class="header-left">
            <a href="./" class="back-arrow" aria-label="Назад" id="backArrow">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 12H5"></path>
                    <path d="M12 19l-7-7 7-7"></path>
                </svg>
            </a>
            <span class="logo">FPV Ladder</span>
        </div>
        <div class="header-right">
            <button class="settings-btn" id="settingsBtn" aria-label="Настройки">
                <svg class="settings-icon" viewBox="0 0 24 24" fill="currentColor">
                    <circle cx="12" cy="6" r="2"></circle>
                    <circle cx="12" cy="12" r="2"></circle>
                    <circle cx="12" cy="18" r="2"></circle>
                </svg>
            </button>
            <div class="settings-dropdown" id="settingsDropdown">
                <button class="settings-close" id="settingsClose" aria-label="Закрыть">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
                <div class="settings-title">Тема</div>
                <button class="menu-option active" data-value="light">
                    <span class="menu-check"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6l3 3 5-5"/></svg></span>
                    <span class="menu-label">Светлая</span>
                </button>
                <button class="menu-option" data-value="dark">
                    <span class="menu-check"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6l3 3 5-5"/></svg></span>
                    <span class="menu-label">Тёмная</span>
                </button>
            </div>
        </div>
    </div>
</header>
{{end}}
