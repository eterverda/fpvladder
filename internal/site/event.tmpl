<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ .Name }} ⟫ FPV Ladder</title>
    <style>
        :root {
            --bg: #ffffff;
            --text: #2d3436;
            --muted: #b2bec3;
            --line: #eee;
            --hover-bg: #fcfcfc;
        }

        body {
            font-family: 'Segoe UI', Roboto, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            display: flex;
            justify-content: center;
            margin: 0;
            padding: 40px 0 80px 0;
        }

        .container { width: 100%; max-width: 600px; }

        .back-link {
            display: inline-block;
            margin: 0 0 30px 20px;
            color: var(--muted);
            text-decoration: none;
            font-size: 0.9rem;
            transition: color 0.2s;
        }
        .back-link:hover { color: var(--text); }

        header { text-align: center; margin-bottom: 50px; padding: 0 20px; }
        h1 { font-weight: 400; font-size: 1.5rem; margin: 0 0 5px 0; }
        .event-date { color: var(--muted); font-size: 0.9rem; }

        h2 { 
            font-size: 0.8rem; 
            font-weight: 700; 
            color: var(--muted); 
            text-transform: uppercase; 
            letter-spacing: 1.5px; 
            margin: 40px 0 10px 50px;
        }

        .data-table { width: 100%; border-collapse: collapse; }
        .data-row { border-bottom: 1px solid var(--line); transition: background 0.1s; cursor: pointer; }
        .data-row:hover { background-color: var(--hover-bg); }
        .data-row td { padding: 14px 8px; -webkit-tap-highlight-color: transparent; }
        .data-row:last-child { border-bottom: none; }

        .data-row a { text-decoration: none; color: inherit; display: block; }

        @media (hover: none) {
            .data-row:active { background-color: #f2f2f2; transition: background 0s; }
        }

        .col-pos {
            text-align: right; width: 30px; font-size: 0.8rem; color: var(--muted);
            white-space: nowrap;
        } 

        .col-name { font-weight: 400; font-size: 1rem; }

        .col-assignment {
            text-align: right; 
            white-space: nowrap;
            padding-right: 20px !important;
            font-weight: 600;
            color: var(--text);
        }

        .copyright {
            margin-top: 80px;
            text-align: center;
            font-size: 0.75rem;
            color: var(--muted);
        }
    </style>
</head>
<body>
    <div class="container">
        <a href="../../../index.html" class="back-link">← Назад к рейтингу</a>

        <header>
            <h1>{{ .Name }}</h1>
            <div class="event-date">{{ .Date }}</div>
        </header>

        <section>
            <h2>Результаты</h2>
            <table class="data-table">
                <tbody>
                    {{ range .Results }}
                    <tr class="data-row" data-href="{{ .Href }}">
                        <td class="col-pos">{{ .Position }}</td>
                        <td class="col-name">
                            <a href="{{ .Href }}">{{ .Name }}</a>
                        </td>
                        <td class="col-assignment">
                            {{ .Assignment }}
                        </td>
                    </tr>
                    {{ end }}
                </tbody>
            </table>
        </section>

        <footer class="copyright">
            FPV Ladder Project &copy; 2026
        </footer>
    </div>

    <script>
        document.addEventListener('click', (e) => {
            const row = e.target.closest('.data-row[data-href]');
            if (row && !e.target.closest('a')) {
                window.location.href = row.dataset.href;
            }
        });
    </script>
</body>
</html>