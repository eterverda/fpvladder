<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ .Name }}</title>
    <link rel="stylesheet" href="../../../styles.css">
</head>
<body>
    {{template "header"}}

    <div class="container">
        <header>
            <div class="pilot-card">
                <div class="pilot-card-name">{{ .Name }}</div>
                <div class="pilot-card-label">рейтинг</div>
                <div class="pilot-card-rating">{{ .Rating }}</div>
            </div>
        </header>

        <section>
            <h2 class="table-header">История соревнований</h2>
            <table class="data-table">
                {{ range .Assignments }}
                <tbody class="event-group" data-href="{{ .Href }}">
                    <tr class="event-row">
                        <td class="col-spacer">{{ .Position }}</td>
                        <td class="col-event"><a href="{{ .Href }}">{{ .Name }}</a></td>
                        <td class="col-date">{{ .Date }}</td>
                    </tr>
                    <tr class="assignment-row">
                        <td class="col-spacer"></td>
                        <td class="col-event">
                            <div class="assignment-container">
                                <span class="assignment-text">{{ .Assignment }}</span>
                            </div>
                        </td>
                        <td class="col-date"></td>
                    </tr>
                </tbody>
                {{ end }}
            </table>
        </section>

        <footer class="copyright">
            &copy; 2026 FPV Ladder Project
        </footer>
    </div>

    <script src="../../../scripts.js"></script>
</body>
</html>
